# Copy this file to `.env` and fill in the secrets before running
# `docker compose up`. `.env` is gitignored.

# --- Infra ---
MONGODB_URL=mongodb://mongo:27017/eth_tx_pipeline
# In-network broker address used by the services. Host-side tooling instead
# connects to the broker's EXTERNAL listener on localhost:29092.
KAFKA_BROKER_URL=kafka:9092
KAFKA_GROUP_ID=message-consumer
KAFKA_TOPIC=transactions

# --- message-consumer ---
# Fixed enrichment rate used until a live exchange-rate provider is introduced.
ETH_USD_EXCHANGE_RATE=3000.0

# --- transactions-historical ---
ETHERSCAN_CONTRACT_ADDRESS=0x88e6A0c2dDD26FEEb64F039a2c41296FcB3f5640
ETHERSCAN_HISTORICAL_FIRST_BLOCK=18000000
ETHERSCAN_HISTORICAL_LAST_BLOCK=18001000
ETHERSCAN_HISTORICAL_BATCH_SIZE=100

# --- transactions-realtime ---
INFURA_POLL_INTERVAL=15

# --- Secrets: leave empty in version control, fill in locally ---
INFURA_PROJECT_ID=
# Empty selects transactions-historical's bundled recorded fixture mode.
ETHERSCAN_API_KEY=
